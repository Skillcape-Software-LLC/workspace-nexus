# ─── Database ────────────────────────────────────────────────
# Path inside the container where SQLite DB is stored
DATABASE_PATH=/app/data/nexus.db

# ─── API Security (optional) ─────────────────────────────────
# If set, all API requests must include header: X-API-Key: <value>
# Leave blank to disable authentication
API_KEY=

# ─── Nexus URLs ──────────────────────────────────────────────
# Base URL used for OAuth redirect URIs (routes through the web container's /api/ proxy)
NEXUS_BASE_URL=http://localhost:4100
# Base URL of the frontend (used for post-auth redirects and CORS)
NEXUS_FRONTEND_URL=http://localhost:4100

# ─── Google OAuth 2.0 (optional) ─────────────────────────────
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: http://localhost:4100/api/google/auth/callback
# Required scopes: Gmail (readonly), Calendar (readonly), Chat (spaces.readonly)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub (optional) ───────────────────────────────────────
# Personal Access Token for reading repo/CI metadata
GITHUB_PAT=

# OAuth App for "Connect GitHub" in Settings
# Create at: https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: http://localhost:4100/api/github/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# HMAC secret for validating incoming GitHub webhook payloads
# If unset, webhooks are accepted without signature verification (logged as warning)
GITHUB_WEBHOOK_SECRET=

# How often (in minutes) to poll GitHub for CI status updates (default: 5)
CI_POLLING_INTERVAL_MINUTES=5

# ─── AI Briefing (optional) ──────────────────────────────────
# Anthropic API key for daily briefing generation
CLAUDE_API_KEY=

# Cron schedule for briefing generation (default: 7:30 AM UTC)
BRIEFING_SCHEDULE=30 7 * * *
