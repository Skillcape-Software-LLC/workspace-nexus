# ─── Database ────────────────────────────────────────────────
# Path inside the container where SQLite DB is stored
DATABASE_PATH=/app/data/nexus.db

# ─── API Security (optional) ─────────────────────────────────
# If set, all API requests must include: X-API-Key: <value>
# Leave blank to disable authentication
API_KEY=

# ─── Google OAuth 2.0 ────────────────────────────────────────
# Create an OAuth 2.0 Client ID in Google Cloud Console
# Application type: Web application
# Authorized redirect URIs: {NEXUS_BASE_URL}/api/google/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Nexus URLs ──────────────────────────────────────────────
# Base URL of the API (used for OAuth redirect URI)
NEXUS_BASE_URL=http://localhost:5100
# Base URL of the frontend (used for post-auth redirect)
NEXUS_FRONTEND_URL=http://localhost:4100

# ─── GitHub ──────────────────────────────────────────────────
# Personal Access Token for reading repo metadata (optional)
GITHUB_PAT=

# HMAC secret for validating incoming GitHub webhook payloads (optional)
GITHUB_WEBHOOK_SECRET=

# How often (in minutes) to poll GitHub for CI status updates (default: 5)
CI_POLLING_INTERVAL_MINUTES=5

# ─── AI Briefing ─────────────────────────────────────────────
# Anthropic Claude API key for daily briefing generation
CLAUDE_API_KEY=

# Cron schedule for briefing generation (default: 7:30am)
BRIEFING_SCHEDULE=30 7 * * *
